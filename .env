# ============================================================
#  Server
# ============================================================
SERVER_PORT=9090
SINGLE_THREAD_SERVER_PORT=9091

# ============================================================
#  Kafka (KRaft — no Zookeeper)
# ============================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=records
KAFKA_GROUP_ID=batch-worker
# acks=1 → leader confirms, good balance of speed vs durability
KAFKA_PRODUCER_ACKS=1
KAFKA_PRODUCER_LINGER_MS=5
KAFKA_PRODUCER_BATCH_BYTES=65536

# ============================================================
#  Batch Worker
# ============================================================
BATCH_SIZE=400
BATCH_FLUSH_TIMEOUT_MS=200
KAFKA_POLL_TIMEOUT_MS=100

# ============================================================
#  Database — SQL Server
# ============================================================
JDBC_URL=jdbc:sqlserver://sqlserver:1433;databaseName=TestVT;encrypt=true;trustServerCertificate=true
DB_USER=sa
DB_PASS=YourPassword123!

# ============================================================
#  SQL Server Docker image settings
# ============================================================
ACCEPT_EULA=Y
MSSQL_SA_PASSWORD=YourPassword123!
MSSQL_PID=Developer
